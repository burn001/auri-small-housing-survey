MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=small_housing_survey

# Secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SECRET=change-me-random-hex
ADMIN_KEY=change-me-random-hex

CORS_ORIGINS=https://your-survey-domain.com,http://localhost:5173

# Public survey URL — used in email invitations ({{survey_url}} in templates)
SURVEY_BASE_URL=https://your-survey-domain.com

# Gmail SMTP — use a Google Account app password (not the login password)
GMAIL_USER=your-sender@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
